{
  "name": "noumen",
  "version": "0.8.1",
  "type": "module",
  "description": "Programmatic AI agent runtime with pluggable providers and sandboxed virtual infrastructure",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "bin": {
    "noumen": "./dist/cli/index.js"
  },
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./mcp": {
      "import": "./dist/mcp/index.js",
      "types": "./dist/mcp/index.d.ts"
    },
    "./lsp": {
      "import": "./dist/lsp/index.js",
      "types": "./dist/lsp/index.d.ts"
    },
    "./server": {
      "import": "./dist/server/index.js",
      "types": "./dist/server/index.d.ts"
    },
    "./client": {
      "import": "./dist/client/index.js",
      "types": "./dist/client/index.d.ts"
    },
    "./acp": {
      "import": "./dist/acp/index.js",
      "types": "./dist/acp/index.d.ts"
    },
    "./a2a": {
      "import": "./dist/a2a/index.js",
      "types": "./dist/a2a/index.d.ts"
    },
    "./jsonrpc": {
      "import": "./dist/jsonrpc/index.js",
      "types": "./dist/jsonrpc/index.d.ts"
    },
    "./docker": {
      "import": "./dist/docker.js",
      "types": "./dist/docker.d.ts"
    },
    "./e2b": {
      "import": "./dist/e2b.js",
      "types": "./dist/e2b.d.ts"
    },
    "./freestyle": {
      "import": "./dist/freestyle.js",
      "types": "./dist/freestyle.d.ts"
    },
    "./ssh": {
      "import": "./dist/ssh.js",
      "types": "./dist/ssh.d.ts"
    },
    "./sprites": {
      "import": "./dist/sprites.js",
      "types": "./dist/sprites.d.ts"
    },
    "./local": {
      "import": "./dist/local.js",
      "types": "./dist/local.d.ts"
    },
    "./unsandboxed": {
      "import": "./dist/unsandboxed.js",
      "types": "./dist/unsandboxed.d.ts"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "dev": "concurrently -n lib,web -c blue,magenta \"tsup --watch\" \"pnpm --filter noumen-docs dev\"",
    "cli": "tsx src/cli/index.ts",
    "prepublishOnly": "pnpm run build",
    "version:major": "npm version major --no-git-tag-version",
    "version:minor": "npm version minor --no-git-tag-version",
    "version:patch": "npm version patch --no-git-tag-version",
    "publish:lib": "pnpm publish --access public --no-git-checks"
  },
  "packageManager": "pnpm@10.8.1",
  "engines": {
    "node": ">=18.0.0"
  },
  "dependencies": {
    "@ai-sdk/provider": "^3.0.8",
    "@anthropic-ai/sandbox-runtime": "^0.0.49",
    "chalk": "^5.4.1",
    "commander": "^13.1.0",
    "node-html-markdown": "^2.0.0",
    "uuid": "^11.1.0"
  },
  "peerDependencies": {
    "@ai-sdk/amazon-bedrock": ">=4.0.0",
    "@ai-sdk/anthropic": ">=3.0.0",
    "@ai-sdk/google": ">=3.0.0",
    "@ai-sdk/google-vertex": ">=4.0.0",
    "@ai-sdk/openai": ">=3.0.0",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@openrouter/ai-sdk-provider": ">=2.0.0",
    "@opentelemetry/api": "^1.0.0",
    "dockerode": ">=4.0.0",
    "e2b": ">=2.0.0",
    "freestyle-sandboxes": ">=0.1.0",
    "ollama-ai-provider-v2": ">=3.0.0",
    "sharp": ">=0.33.0",
    "ssh2": ">=1.0.0",
    "vscode-jsonrpc": "^8.2.1",
    "ws": ">=8.0.0"
  },
  "peerDependenciesMeta": {
    "@ai-sdk/amazon-bedrock": {
      "optional": true
    },
    "@ai-sdk/anthropic": {
      "optional": true
    },
    "@ai-sdk/google": {
      "optional": true
    },
    "@ai-sdk/google-vertex": {
      "optional": true
    },
    "@ai-sdk/openai": {
      "optional": true
    },
    "@modelcontextprotocol/sdk": {
      "optional": true
    },
    "@openrouter/ai-sdk-provider": {
      "optional": true
    },
    "@opentelemetry/api": {
      "optional": true
    },
    "dockerode": {
      "optional": true
    },
    "e2b": {
      "optional": true
    },
    "freestyle-sandboxes": {
      "optional": true
    },
    "ollama-ai-provider-v2": {
      "optional": true
    },
    "sharp": {
      "optional": true
    },
    "ssh2": {
      "optional": true
    },
    "vscode-jsonrpc": {
      "optional": true
    },
    "ws": {
      "optional": true
    }
  },
  "devDependencies": {
    "@ai-sdk/anthropic": "^3.0.71",
    "@ai-sdk/google": "^3.0.64",
    "@ai-sdk/openai": "^3.0.53",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@opentelemetry/api": "^1.9.1",
    "@types/dockerode": "^4.0.1",
    "@types/node": "^22.0.0",
    "@types/uuid": "^10.0.0",
    "@types/ws": "^8.5.0",
    "@vitest/coverage-v8": "^3.2.4",
    "concurrently": "^9.2.1",
    "freestyle-sandboxes": "^0.1.42",
    "tsup": "^8.4.0",
    "tsx": "^4.21.0",
    "typescript": "^5.7.0",
    "vitest": "^3.0.0",
    "vscode-jsonrpc": "^8.2.1",
    "ws": "^8.18.0"
  }
}
