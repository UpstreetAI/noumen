{
  "name": "noumen",
  "version": "0.1.0",
  "type": "module",
  "description": "Programmatic AI coding agent library with pluggable providers and virtual infrastructure",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "dev": "concurrently -n lib,web -c blue,magenta \"tsup --watch\" \"pnpm --filter noumen-docs dev\"",
    "prepublishOnly": "pnpm run build",
    "publish:lib": "pnpm publish --access public --no-git-checks"
  },
  "packageManager": "pnpm@10.8.1",
  "engines": {
    "node": ">=18.0.0"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.39.0",
    "@google/genai": "^1.48.0",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "node-html-markdown": "^2.0.0",
    "openai": "^4.85.0",
    "uuid": "^11.1.0",
    "vscode-jsonrpc": "^8.2.1"
  },
  "peerDependencies": {
    "@opentelemetry/api": "^1.0.0"
  },
  "peerDependenciesMeta": {
    "@opentelemetry/api": {
      "optional": true
    }
  },
  "devDependencies": {
    "@opentelemetry/api": "^1.9.1",
    "@types/node": "^22.0.0",
    "@types/uuid": "^10.0.0",
    "@vitest/coverage-v8": "^3.2.4",
    "concurrently": "^9.2.1",
    "tsup": "^8.4.0",
    "typescript": "^5.7.0",
    "vitest": "^3.0.0"
  }
}
