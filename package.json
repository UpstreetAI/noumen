{
  "name": "noumen",
  "version": "0.4.0",
  "type": "module",
  "description": "Programmatic AI agent runtime with pluggable providers and sandboxed virtual infrastructure",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "bin": {
    "noumen": "./dist/cli/index.js"
  },
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./openai": {
      "import": "./dist/providers/openai.js",
      "types": "./dist/providers/openai.d.ts"
    },
    "./anthropic": {
      "import": "./dist/providers/anthropic.js",
      "types": "./dist/providers/anthropic.d.ts"
    },
    "./gemini": {
      "import": "./dist/providers/gemini.js",
      "types": "./dist/providers/gemini.d.ts"
    },
    "./openrouter": {
      "import": "./dist/providers/openrouter.js",
      "types": "./dist/providers/openrouter.d.ts"
    },
    "./bedrock": {
      "import": "./dist/providers/bedrock.js",
      "types": "./dist/providers/bedrock.d.ts"
    },
    "./vertex": {
      "import": "./dist/providers/vertex.js",
      "types": "./dist/providers/vertex.d.ts"
    },
    "./ollama": {
      "import": "./dist/providers/ollama.js",
      "types": "./dist/providers/ollama.d.ts"
    },
    "./mcp": {
      "import": "./dist/mcp/index.js",
      "types": "./dist/mcp/index.d.ts"
    },
    "./lsp": {
      "import": "./dist/lsp/index.js",
      "types": "./dist/lsp/index.d.ts"
    },
    "./server": {
      "import": "./dist/server/index.js",
      "types": "./dist/server/index.d.ts"
    },
    "./client": {
      "import": "./dist/client/index.js",
      "types": "./dist/client/index.d.ts"
    },
    "./acp": {
      "import": "./dist/acp/index.js",
      "types": "./dist/acp/index.d.ts"
    },
    "./a2a": {
      "import": "./dist/a2a/index.js",
      "types": "./dist/a2a/index.d.ts"
    },
    "./jsonrpc": {
      "import": "./dist/jsonrpc/index.js",
      "types": "./dist/jsonrpc/index.d.ts"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "dev": "concurrently -n lib,web -c blue,magenta \"tsup --watch\" \"pnpm --filter noumen-docs dev\"",
    "cli": "tsx src/cli/index.ts",
    "prepublishOnly": "pnpm run build",
    "version:major": "npm version major --no-git-tag-version",
    "version:minor": "npm version minor --no-git-tag-version",
    "version:patch": "npm version patch --no-git-tag-version",
    "publish:lib": "pnpm publish --access public --no-git-checks"
  },
  "packageManager": "pnpm@10.8.1",
  "engines": {
    "node": ">=18.0.0"
  },
  "dependencies": {
    "@anthropic-ai/sandbox-runtime": "^0.0.49",
    "chalk": "^5.4.1",
    "commander": "^13.1.0",
    "node-html-markdown": "^2.0.0",
    "uuid": "^11.1.0"
  },
  "peerDependencies": {
    "@anthropic-ai/bedrock-sdk": ">=0.10.0",
    "@anthropic-ai/sdk": "^0.39.0",
    "@anthropic-ai/vertex-sdk": ">=0.4.0",
    "@google/genai": "^1.48.0",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@opentelemetry/api": "^1.0.0",
    "dockerode": ">=4.0.0",
    "e2b": ">=2.0.0",
    "freestyle-sandboxes": ">=0.1.0",
    "google-auth-library": ">=9.0.0",
    "openai": "^4.85.0",
    "sharp": ">=0.33.0",
    "ssh2": ">=1.0.0",
    "vscode-jsonrpc": "^8.2.1",
    "ws": ">=8.0.0"
  },
  "peerDependenciesMeta": {
    "@anthropic-ai/sdk": {
      "optional": true
    },
    "@google/genai": {
      "optional": true
    },
    "@modelcontextprotocol/sdk": {
      "optional": true
    },
    "openai": {
      "optional": true
    },
    "vscode-jsonrpc": {
      "optional": true
    },
    "@opentelemetry/api": {
      "optional": true
    },
    "@anthropic-ai/bedrock-sdk": {
      "optional": true
    },
    "@anthropic-ai/vertex-sdk": {
      "optional": true
    },
    "google-auth-library": {
      "optional": true
    },
    "dockerode": {
      "optional": true
    },
    "e2b": {
      "optional": true
    },
    "freestyle-sandboxes": {
      "optional": true
    },
    "ws": {
      "optional": true
    },
    "sharp": {
      "optional": true
    },
    "ssh2": {
      "optional": true
    }
  },
  "devDependencies": {
    "@anthropic-ai/sdk": "^0.39.0",
    "@google/genai": "^1.48.0",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@opentelemetry/api": "^1.9.1",
    "@types/dockerode": "^4.0.1",
    "@types/node": "^22.0.0",
    "@types/uuid": "^10.0.0",
    "@types/ws": "^8.5.0",
    "@vitest/coverage-v8": "^3.2.4",
    "concurrently": "^9.2.1",
    "freestyle-sandboxes": "^0.1.42",
    "openai": "^4.85.0",
    "tsup": "^8.4.0",
    "tsx": "^4.21.0",
    "typescript": "^5.7.0",
    "vitest": "^3.0.0",
    "vscode-jsonrpc": "^8.2.1",
    "ws": "^8.18.0"
  }
}
